# Environment Configuration

# Server
PORT=3000

# Timeouts
REQUEST_TIMEOUT_MS=30000
TOKEN_REFRESH_BUFFER_MS=300000

# Limits
MAX_REQUEST_SIZE=1048576

# Authentication (optional - uncomment to enable)
# PROXY_API_KEY=your-secret-key-here

# Rate Limiting (optional - uncomment to enable)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000

# Retry
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Kiro API (advanced - usually not needed)
# KIRO_API_BASE=https://codewhisperer.us-east-1.amazonaws.com
